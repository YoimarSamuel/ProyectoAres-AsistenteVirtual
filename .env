# ARES v2.0 - Configuración

# ======================== DIRECTORIOS ========================
# Rutas base para búsqueda de proyectos
PROYECTOS_BASE=/Users/tuusuario/proyectos

# ======================== CONFIGURACIÓN ARES ========================
# Modo debug (verbose output con icecream)
ARES_DEBUG=True

# Modo autónomo (ARES toma decisiones sin preguntar)
ARES_AUTONOMO=True

# Memoria activa (guardar todas las interacciones)
ARES_MEMORIA_ACTIVA=True

# Visión activa (análisis de cámara continuo)
ARES_VISION_ACTIVA=True

# RPA activo (automatización del sistema)
ARES_RPA_ACTIVO=True

# ======================== VISIÓN ========================
# Intervalo de análisis en segundos
VISION_INTERVALO=5

# Índice de cámara (0 = cámara por defecto)
VISION_CAMERA_INDEX=0

# Resolución de análisis
VISION_RESOLUCION=640x480

# ======================== PLN ========================
# Temperature de LLM (0.0-1.0, menor = más determinista)
PLN_TEMPERATURE=0.3

# Top-P (0.0-1.0)
PLN_TOP_P=0.8

# Máximo de tokens por respuesta
PLN_MAX_TOKENS=150

# ======================== RUTAS DE APLICACIONES ========================
# Rutas personalizadas a aplicaciones
VSCODE_PATH=C:\\Program Files\\Microsoft VS Code\\Code.exe
TERMINAL_CMD=cmd
EDITOR_PREFERIDO=vscode

# ======================== INTEGRACIONES ========================
# Habilitar delegación a Kiro
INTEGRAR_KIRO=True

# Habilitar delegación a Claude Code
INTEGRAR_CLAUDE_CODE=True

# Habilitar delegación a Antigravity
INTEGRAR_ANTIGRAVITY=False
